{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "typechain-types/**/*",
    "test/contracts/hardhat-jest.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
